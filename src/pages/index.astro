---
import Layout from "../layouts/Layout.astro";
import routeData from "../data/routes.json";
import completionData from "../data/completed-routes.json";

const { worlds, routes, totalRoutes } = routeData;
const { completedRoutes, totalCompleted } = completionData;

// Build a map of completed routes by slug
const completedMap = new Map<string, any>();
for (const c of completedRoutes) {
  completedMap.set(c.routeSlug, c);
}

// Group routes by world
const sortedWorlds = worlds
  .filter((w: any) => w.routeCount > 0)
  .sort((a: any, b: any) => b.routeCount - a.routeCount);

// Per-world completion counts
const worldCompletion: Record<string, { done: number; total: number }> = {};
for (const route of routes) {
  if (!worldCompletion[route.world]) worldCompletion[route.world] = { done: 0, total: 0 };
  worldCompletion[route.world].total++;
  if (completedMap.has(route.slug)) worldCompletion[route.world].done++;
}

const routesByWorld: Record<string, any[]> = {};
for (const route of routes) {
  if (!routesByWorld[route.world]) routesByWorld[route.world] = [];
  routesByWorld[route.world].push(route);
}

function formatDistance(km: number): string {
  return `${km.toFixed(1)} km`;
}

function formatElevation(m: number): string {
  return `${Math.round(m)} m`;
}

// World colors for visual variety
const worldColors: Record<string, { bg: string; border: string; text: string; accent: string }> = {
  watopia:        { bg: "bg-emerald-500/10", border: "border-emerald-500/30", text: "text-emerald-400", accent: "bg-emerald-500" },
  "new-york":     { bg: "bg-blue-500/10",    border: "border-blue-500/30",    text: "text-blue-400",    accent: "bg-blue-500" },
  "makuri-islands": { bg: "bg-pink-500/10",  border: "border-pink-500/30",    text: "text-pink-400",    accent: "bg-pink-500" },
  london:         { bg: "bg-red-500/10",     border: "border-red-500/30",     text: "text-red-400",     accent: "bg-red-500" },
  france:         { bg: "bg-indigo-500/10",  border: "border-indigo-500/30",  text: "text-indigo-400",  accent: "bg-indigo-500" },
  scotland:       { bg: "bg-cyan-500/10",    border: "border-cyan-500/30",    text: "text-cyan-400",    accent: "bg-cyan-500" },
  richmond:       { bg: "bg-amber-500/10",   border: "border-amber-500/30",   text: "text-amber-400",   accent: "bg-amber-500" },
  yorkshire:      { bg: "bg-lime-500/10",    border: "border-lime-500/30",    text: "text-lime-400",    accent: "bg-lime-500" },
  innsbruck:      { bg: "bg-violet-500/10",  border: "border-violet-500/30",  text: "text-violet-400",  accent: "bg-violet-500" },
  paris:          { bg: "bg-rose-500/10",    border: "border-rose-500/30",    text: "text-rose-400",    accent: "bg-rose-500" },
  "crit-city":    { bg: "bg-orange-500/10",  border: "border-orange-500/30",  text: "text-orange-400",  accent: "bg-orange-500" },
  bologna:        { bg: "bg-teal-500/10",    border: "border-teal-500/30",    text: "text-teal-400",    accent: "bg-teal-500" },
};

function getWorldColor(slug: string) {
  return worldColors[slug] || { bg: "bg-gray-500/10", border: "border-gray-500/30", text: "text-gray-400", accent: "bg-gray-500" };
}
---

<Layout title="Zwift Route Tracker">
  <!-- Hero Stats -->
  <div class="mb-10">
    <div class="flex flex-wrap items-end gap-8 mb-2">
      <div>
        <div class="text-5xl font-extrabold text-white tracking-tight">
          {totalCompleted}<span class="text-2xl text-gray-500 font-semibold">/{totalRoutes}</span>
        </div>
        <div class="text-sm text-gray-500 font-medium">routes completed</div>
      </div>
      <div>
        <div class="text-3xl font-bold text-zwift-orange">{Math.round((totalCompleted / totalRoutes) * 100)}%</div>
        <div class="text-sm text-gray-500 font-medium">completion</div>
      </div>
    </div>

    <!-- Overall progress bar -->
    <div class="h-3 rounded-full overflow-hidden bg-zwift-dark mt-4">
      <div
        class="h-full bg-gradient-to-r from-zwift-orange to-zwift-orange-light rounded-full transition-all"
        style={`width: ${(totalCompleted / totalRoutes) * 100}%`}
      />
    </div>

    <!-- World completion bars -->
    <div class="flex gap-1 h-4 rounded-full overflow-hidden bg-zwift-dark mt-4">
      {sortedWorlds.map((w: any) => {
        const color = getWorldColor(w.slug);
        const widthPercent = (w.routeCount / totalRoutes) * 100;
        const wc = worldCompletion[w.slug] || { done: 0, total: 0 };
        const completionPercent = wc.total > 0 ? (wc.done / wc.total) * 100 : 0;
        return (
          <div
            class="relative overflow-hidden cursor-pointer group"
            style={`width: ${widthPercent}%`}
            title={`${w.name}: ${wc.done}/${wc.total} completed`}
            data-world-bar={w.slug}
          >
            {/* Background (uncompleted portion) */}
            <div class={`absolute inset-0 ${color.accent} opacity-20 group-hover:opacity-30 transition-opacity`} />
            {/* Filled (completed portion) */}
            <div
              class={`absolute inset-y-0 left-0 ${color.accent} opacity-80 group-hover:opacity-100 transition-opacity`}
              style={`width: ${completionPercent}%`}
            />
          </div>
        );
      })}
    </div>
  </div>

  <!-- Controls Bar -->
  <div class="flex flex-wrap items-center gap-3 mb-6">
    <div class="relative flex-1 min-w-[120px]">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        type="text"
        id="search"
        placeholder="Search routes..."
        class="w-full bg-zwift-card border border-gray-700/50 rounded-lg pl-10 pr-4 py-2.5 text-sm focus:border-zwift-orange focus:outline-none focus:ring-1 focus:ring-zwift-orange/30 placeholder-gray-600 transition-all"
      />
    </div>

    <div class="flex items-center gap-1 bg-zwift-card border border-gray-700/50 rounded-lg p-1">
      <button data-status="all" class="status-btn active px-3 py-1.5 text-xs font-medium rounded-md transition-all">All</button>
      <button data-status="completed" class="status-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all">✓ Done</button>
      <button data-status="todo" class="status-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all">○ To Do</button>
    </div>

    <div class="flex items-center gap-1 bg-zwift-card border border-gray-700/50 rounded-lg p-1">
      <button data-event-filter="include" class="event-btn active px-3 py-1.5 text-xs font-medium rounded-md transition-all">All Routes</button>
      <button data-event-filter="exclude" class="event-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all">Hide Events</button>
    </div>

    <div class="flex items-center gap-1 bg-zwift-card border border-gray-700/50 rounded-lg p-1">
      <button data-sort="name" class="sort-btn active px-3 py-1.5 text-xs font-medium rounded-md transition-all">Name</button>
      <button data-sort="distance-asc" class="sort-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all">Shortest</button>
      <button data-sort="distance-desc" class="sort-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all">Longest</button>
      <button data-sort="elevation-desc" class="sort-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all">Hilliest</button>
      <button data-sort="gradient-desc" class="sort-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all">Steepest</button>
      <button data-sort="experience-desc" class="sort-btn px-3 py-1.5 text-xs font-medium rounded-md transition-all">Most XP</button>
    </div>
  </div>

  <!-- World Tabs -->
  <div class="flex gap-2 mb-6 overflow-x-auto pb-2 scrollbar-thin" id="world-tabs">
    <button
      class="world-tab active whitespace-nowrap px-4 py-2 rounded-lg text-sm font-medium transition-all border"
      data-world="all"
    >
      All Worlds
      <span class="ml-1.5 text-xs opacity-60">{totalCompleted}/{totalRoutes}</span>
    </button>
    {sortedWorlds.map((w: any) => {
      const color = getWorldColor(w.slug);
      const wc = worldCompletion[w.slug] || { done: 0, total: 0 };
      return (
        <button
          class={`world-tab whitespace-nowrap px-4 py-2 rounded-lg text-sm font-medium transition-all border`}
          data-world={w.slug}
          data-color-bg={color.bg}
          data-color-border={color.border}
          data-color-text={color.text}
        >
          {w.name}
          <span class="ml-1.5 text-xs opacity-60">{wc.done}/{wc.total}</span>
        </button>
      );
    })}
  </div>

  <!-- Route count -->
  <div class="text-xs text-gray-500 mb-3 font-medium uppercase tracking-wider">
    <span id="visible-count">{totalRoutes}</span> routes
  </div>

  <!-- Route Cards / Table -->
  <div class="space-y-1" id="route-list">
    {routes.map((route: any) => {
      const color = getWorldColor(route.world);
      const maxDist = 200;
      const distPercent = Math.min((route.distance / maxDist) * 100, 100);
      const completion = completedMap.get(route.slug);
      const isCompleted = !!completion;
      return (
        <div
          class={`route-row group flex items-center gap-4 px-4 py-3 rounded-lg hover:bg-zwift-card/80 transition-all cursor-default border border-transparent hover:border-gray-700/30`}
          data-world={route.world}
          data-name={route.name.toLowerCase()}
          data-distance={route.distance}
          data-elevation={route.elevation}
          data-gradient={route.gradient}
          data-experience={route.experience}
          data-world-name={route.worldName}
          data-completed={isCompleted ? "true" : "false"}
          data-event-only={route.eventOnly ? "true" : "false"}
        >
          {/* Completion check */}
          <div class="w-6 flex-shrink-0 text-center">
            {isCompleted ? (
              <span class="text-green-400 text-lg" title={`Completed ${new Date(completion.date).toLocaleDateString()}`}>✓</span>
            ) : (
              <span class="text-gray-700 text-lg">○</span>
            )}
          </div>

          {/* Color indicator */}
          <div class={`w-1 h-10 rounded-full ${color.accent} ${isCompleted ? 'opacity-80' : 'opacity-20'} group-hover:opacity-80 transition-opacity flex-shrink-0`} />

          {/* Route name & world */}
          <div class="flex-1 min-w-0">
            <div class={`font-semibold group-hover:text-zwift-orange-light transition-colors truncate ${isCompleted ? 'text-white' : 'text-gray-400'}`}>
              {route.name}
            </div>
            <div class="flex items-center gap-2">
              <span class={`text-xs ${color.text} opacity-70`}>{route.worldName}</span>
              {isCompleted && (
                <a href={completion.stravaUrl} target="_blank" rel="noopener"
                   class="text-[10px] text-gray-600 hover:text-zwift-orange transition-colors">
                  {new Date(completion.date).toLocaleDateString()} • Strava ↗
                </a>
              )}
            </div>
          </div>

          {/* Tags */}
          <div class="hidden sm:flex items-center gap-1.5 flex-shrink-0">
            {route.eventOnly && (
              <span class="text-[10px] font-semibold uppercase tracking-wider bg-yellow-500/15 text-yellow-400 px-2 py-0.5 rounded-full border border-yellow-500/20" title="Only available during events, not in free ride">
                Event
              </span>
            )}
            {route.lap && (
              <span class="text-[10px] font-semibold uppercase tracking-wider bg-blue-500/15 text-blue-400 px-2 py-0.5 rounded-full border border-blue-500/20">
                Lap
              </span>
            )}
            {route.levelLocked && (
              <span class="text-[10px] font-semibold uppercase tracking-wider bg-purple-500/15 text-purple-400 px-2 py-0.5 rounded-full border border-purple-500/20" title="Locked until you reach a certain level in Zwift">
                🔒
              </span>
            )}
          </div>

          {/* Distance bar */}
          <div class="hidden md:flex items-center gap-2 w-40 flex-shrink-0">
            <div class="flex-1 h-1.5 bg-zwift-dark rounded-full overflow-hidden">
              <div class={`h-full ${color.accent} opacity-50 rounded-full`} style={`width: ${distPercent}%`} />
            </div>
            <span class="text-xs text-gray-400 w-16 text-right font-mono">{formatDistance(route.distance)}</span>
          </div>

          {/* Elevation */}
          <div class="hidden lg:flex items-center gap-1 w-20 flex-shrink-0 justify-end">
            <svg class="w-3 h-3 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 17l6-8 4 5 6-10v13H2z" />
            </svg>
            <span class="text-xs text-gray-400 font-mono">{formatElevation(route.elevation)}</span>
          </div>

          {/* Gradient */}
          <div class="hidden lg:flex items-center gap-1 w-16 flex-shrink-0 justify-end">
            <span class={`text-xs font-mono ${route.gradient >= 3 ? 'text-red-400' : route.gradient >= 1.5 ? 'text-yellow-400' : 'text-green-400'}`}>
              {route.gradient.toFixed(1)}%
            </span>
          </div>

          {/* XP */}
          <div class="hidden lg:flex items-center gap-1 w-16 flex-shrink-0 justify-end">
            <span class="text-xs text-zwift-orange font-mono">{route.experience}</span>
            <span class="text-[10px] text-gray-600">XP</span>
          </div>

          {/* Links */}
          <div class="hidden xl:flex gap-2 flex-shrink-0 w-14">
            {route.zwiftInsiderUrl && (
              <a
                href={route.zwiftInsiderUrl}
                target="_blank"
                rel="noopener"
                class="text-[10px] text-gray-600 hover:text-zwift-orange transition-colors uppercase tracking-wider font-semibold"
              >
                Insider
              </a>
            )}
          </div>
        </div>
      );
    })}
  </div>
</Layout>

<style>
  .world-tab {
    background: transparent;
    border-color: transparent;
    color: #9ca3af;
  }
  .world-tab:hover {
    background: rgba(255,255,255,0.03);
    border-color: rgba(255,255,255,0.08);
    color: #e5e7eb;
  }
  .world-tab.active {
    background: rgba(252, 103, 25, 0.1);
    border-color: rgba(252, 103, 25, 0.3);
    color: #FC6719;
  }
  .sort-btn {
    color: #6b7280;
  }
  .sort-btn:hover {
    color: #d1d5db;
  }
  .sort-btn.active {
    background: rgba(252, 103, 25, 0.15);
    color: #FC6719;
  }
  .status-btn {
    color: #6b7280;
  }
  .status-btn:hover {
    color: #d1d5db;
  }
  .status-btn.active {
    background: rgba(252, 103, 25, 0.15);
    color: #FC6719;
  }
  .event-btn {
    color: #6b7280;
  }
  .event-btn:hover {
    color: #d1d5db;
  }
  .event-btn.active {
    background: rgba(252, 103, 25, 0.15);
    color: #FC6719;
  }
</style>

<script>
  const searchInput = document.getElementById("search") as HTMLInputElement;
  const statusBtns = document.querySelectorAll(".status-btn");
  const eventBtns = document.querySelectorAll(".event-btn");
  const visibleCount = document.getElementById("visible-count")!;
  const routeList = document.getElementById("route-list")!;
  const worldTabs = document.querySelectorAll(".world-tab");
  const sortBtns = document.querySelectorAll(".sort-btn");
  const worldBars = document.querySelectorAll("[data-world-bar]");

  let activeWorld = "all";
  let activeSort = "name";
  let activeStatus = "all";
  let activeEventFilter = "include";

  function applyFilters() {
    const search = searchInput.value.toLowerCase();
    const rows = Array.from(routeList.querySelectorAll(".route-row")) as HTMLElement[];

    let count = 0;
    for (const row of rows) {
      const worldMatch = activeWorld === "all" || row.dataset.world === activeWorld;
      const searchMatch = !search || row.dataset.name!.includes(search);
      const statusMatch = activeStatus === "all" ||
        (activeStatus === "completed" && row.dataset.completed === "true") ||
        (activeStatus === "todo" && row.dataset.completed === "false");
      const eventMatch = activeEventFilter === "include" || row.dataset.eventOnly !== "true";

      const visible = worldMatch && searchMatch && statusMatch && eventMatch;
      row.style.display = visible ? "" : "none";
      if (visible) count++;
    }

    visibleCount.textContent = String(count);
  }

  function applySorting() {
    const rows = Array.from(routeList.querySelectorAll(".route-row")) as HTMLElement[];

    rows.sort((a, b) => {
      switch (activeSort) {
        case "name":
          return a.dataset.name!.localeCompare(b.dataset.name!);
        case "distance-asc":
          return parseFloat(a.dataset.distance!) - parseFloat(b.dataset.distance!);
        case "distance-desc":
          return parseFloat(b.dataset.distance!) - parseFloat(a.dataset.distance!);
        case "elevation-desc":
          return parseFloat(b.dataset.elevation!) - parseFloat(a.dataset.elevation!);
        case "gradient-desc":
          return parseFloat(b.dataset.gradient!) - parseFloat(a.dataset.gradient!);
        case "experience-desc":
          return parseFloat(b.dataset.experience!) - parseFloat(a.dataset.experience!);
        default:
          return 0;
      }
    });

    for (const row of rows) {
      routeList.appendChild(row);
    }
  }

  // World tab clicks
  worldTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      worldTabs.forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");
      activeWorld = (tab as HTMLElement).dataset.world!;
      applyFilters();
    });
  });

  // World bar clicks
  worldBars.forEach((bar) => {
    bar.addEventListener("click", () => {
      const slug = (bar as HTMLElement).dataset.worldBar!;
      worldTabs.forEach((t) => {
        t.classList.remove("active");
        if ((t as HTMLElement).dataset.world === slug) t.classList.add("active");
      });
      activeWorld = slug;
      applyFilters();
    });
  });

  // Sort button clicks
  sortBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      sortBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeSort = (btn as HTMLElement).dataset.sort!;
      applySorting();
      applyFilters();
    });
  });

  // Status button clicks
  statusBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      statusBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeStatus = (btn as HTMLElement).dataset.status!;
      applyFilters();
    });
  });

  // Event filter button clicks
  eventBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      eventBtns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      activeEventFilter = (btn as HTMLElement).dataset.eventFilter!;
      applyFilters();
    });
  });

  // Filter inputs
  searchInput.addEventListener("input", applyFilters);
</script>
